{
  "name": "omar-frontend",
  "private": true,
  "version": "1.1.54",
  "type": "module",
  "description": "Frontend for Hafsa — an Islamic marriage platform",
  "license": "MIT",
  "author": "Hafsa Project",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amr1977/OMAR.git"
  },
  "homepage": "https://github.com/Amr1977/OMAR#readme",
  "bugs": {
    "url": "https://github.com/Amr1977/OMAR/issues"
  },
  "keywords": [
    "islamic",
    "marriage",
    "matchmaking",
    "muslim",
    "nikah",
    "react",
    "tailwind"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "generate:og": "node scripts/generate-og.cjs",
    "test:e2e": "playwright test",
    "electron:start": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "tsc -b && vite build && electron-builder --config electron-builder.json --publish never",
    "electron:build:win": "tsc -b && vite build && electron-builder --config electron-builder.json --win --publish never",
    "electron:build:mac": "tsc -b && vite build && electron-builder --config electron-builder.json --mac --publish never",
    "electron:build:linux": "tsc -b && vite build && electron-builder --config electron-builder.json --linux --publish never"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@types/leaflet": "^1.9.21",
    "emoji-picker-react": "^4.19.1",
    "firebase": "^10.14.1",
    "i18next": "^24.0.5",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-i18next": "^15.1.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tailwindcss-rtl": "^0.9.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "wait-on": "^8.0.3"
  },
  "main": "electron/main.js"
}
