generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  GROOM
  GUARDIAN
  SOCIAL
  ADMIN
}

enum ProfileStatus {
  DRAFT
  PENDING_AI_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum MarriageNumber {
  FIRST
  SECOND
  THIRD
  FOURTH
}

enum MadhabType {
  HANAFI
  MALIKI
  SHAFII
  HANBALI
  OTHER
}

enum PrayerCommitment {
  ALWAYS
  MOSTLY
  SOMETIMES
  WORKING_ON_IT
}

enum QuranMemorization {
  FULL
  THREE_QUARTERS
  HALF
  QUARTER
  SOME_SURAHS
  FATIHA_ONLY
  NONE
}

enum MaritalStatus {
  SINGLE
  MARRIED_SEEKING_SECOND
  MARRIED_SEEKING_THIRD
  MARRIED_SEEKING_FOURTH
  DIVORCED
  WIDOWED
}

enum SubscriptionPlan {
  FREE
  PREMIUM
}

enum PostPrivacy {
  PUBLIC
  PRIVATE
  CONNECTIONS
  SELECTED
}

enum StoryPrivacy {
  PUBLIC
  FOLLOWERS
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum ServiceRequestStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  CANCELLED
}

enum MarketplacePaymentStatus {
  PENDING
  PAID
  REFUNDED
  DISPUTED
}

enum GroupPrivacy {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum GroupMemberRole {
  ADMIN
  MODERATOR
  MEMBER
}

model User {
  id                String           @id @default(cuid())
  firebaseUid       String           @unique
  phone             String?          @unique
  email             String?          @unique
  roles             Json             @default("[\"SOCIAL\"]")
  subscriptionPlan  SubscriptionPlan @default(FREE)
  subscriptionExpiry DateTime?
  isVerified        Boolean          @default(false)
  isActive          Boolean          @default(true)
  isBanned          Boolean          @default(false)
  language          String           @default("ar")
  averageRating     Float?
  reviewCount       Int              @default(0)
  isVerifiedSeller  Boolean          @default(false)
  bio               String?          @db.Text
  tagline           String?
  websiteUrl        String?
  lastSeenAt        DateTime?
  isOnline          Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  profile           Profile?
  sentRequests      ContactRequest[] @relation("SentRequests")
  receivedRequests  ContactRequest[] @relation("ReceivedRequests")
  sentMessages      Message[]        @relation("SentMessages")
  conversations     ConversationParticipant[]
  notifications     Notification[]
  reports           Report[]         @relation("Reporter")
  reportedIn        Report[]         @relation("Reported")
  posts             Post[]
  postLikes         PostLike[]
  postComments      PostComment[]
  postPrivacy       PostPrivacyUser[]
  followers         Follow[]         @relation("Follower")
  following         Follow[]         @relation("Following")
  pushTokens        PushToken[]
  feedback          Feedback[]
  subscriptions     Subscription[]
  donations         Donation[]
  brides            Bride[]
  brideExposures    BrideExposure[]   @relation("GroomExposures")
  services          Service[]         @relation("ProviderServices")
  serviceBookings   ServiceBooking[]  @relation("ClientBookings")
  serviceReviews    ServiceReview[]   @relation("ReviewerReviews")
  store             Store?
  cart             Cart?
  orders           Order[]           @relation("BuyerOrders")

  sentConnectionRequests     ConnectionRequest[] @relation("SentConnections")
  receivedConnectionRequests ConnectionRequest[] @relation("ReceivedConnections")
  serviceRequests  ServiceRequest[]  @relation
  serviceOffers    ServiceOffer[]    @relation("ProviderOffers")
  createdGroups    Group[]           @relation("CreatedGroups")
  groupMemberships GroupMember[]

  savedPosts       PostSave[]
  postMentions     PostMention[]
  blockedBy        Block[]           @relation("BlockedUser")
  blocking         Block[]           @relation("BlockingUser")
  postCommentLikes PostCommentLike[]
  postViews        PostView[]
  stories          Story[]
  postReports      PostReport[]      @relation("PostReporter")
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   @default("web")
  createdAt DateTime @default(now())

  @@index([userId])
}

model Profile {
  id                    String              @id @default(cuid())
  userId                String              @unique
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName           String
  age                   Int
  dateOfBirth           String?
  weight                Int?
  height                Int?
  skinColor             String?
  beard                 String?
  sports                String?
  healthIssues          String?
  nationality           String
  countryOfResidence    String
  city                  String
  education             String
  educationLevel        String?
  occupation            String
  workType              String?
  incomeLevel           String?
  maritalStatus         MaritalStatus
  marriageNumber        MarriageNumber
  lastDivorceDate       String?
  hasChildren           Boolean             @default(false)
  numberOfChildren      Int?
  childrenDetails       String?             @db.Text
  childrenCustody       String?
  wantsPolygamy         Boolean?
  wantsChildren         Boolean?

  fatherOccupation      String?
  motherOccupation      String?
  siblingsCount         Int?
  siblingsEducation     String?

  originGovernorate     String?
  residenceGovernorate  String?
  areaType              String?
  marriedResidence      String?
  housingType           String?
  housingPrivacy        String?

  madhab                MadhabType
  prayerCommitment      PrayerCommitment
  quranMemorization     QuranMemorization
  religiousDescription  String?             @db.Text
  smoking               String?

  selfIntroduction      String              @db.Text
  additionalNotes       String?             @db.Text

  wifeAgeMin            Int
  wifeAgeMax            Int
  wifeNationality       String?
  wifeCountry           String?
  wifeEducation         String?
  wifeMaritalStatus     String
  wifeHasChildren       String
  wifeReligiousLevel    String
  wifePreferredSkinColor String?
  wifePreferredHijab    String?
  wifePreferredWork     String?
  wifeAcceptDivorcedWithChildren String?
  wifeAcceptDivorcedChildrenCustody String?
  wifeAcceptOtherCity   Boolean?
  wifeFurnishApartment  String?
  wifeAdditionalNotes   String?             @db.Text

  photos                ProfilePhoto[]

  status                ProfileStatus       @default(DRAFT)
  aiReviewScore         Float?
  aiReviewNotes         String?             @db.Text
  aiReviewedAt          DateTime?
  publishedAt           DateTime?
  viewCount             Int                 @default(0)
  requestCount          Int                 @default(0)

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  contactRequests       ContactRequest[]
}

model ProfilePhoto {
  id            String   @id @default(cuid())
  profileId     String
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  url           String
  cloudinaryId  String?
  isPrimary     Boolean  @default(false)
  order         Int      @default(0)
  isApproved    Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model ContactRequest {
  id           String   @id @default(cuid())
  senderId     String
  sender       User     @relation("SentRequests", fields: [senderId], references: [id])
  profileId    String
  profile      Profile  @relation(fields: [profileId], references: [id])
  receiverId   String
  receiver     User     @relation("ReceivedRequests", fields: [receiverId], references: [id])
  brideId      String?
  bride        Bride?   @relation(fields: [brideId], references: [id], onDelete: SetNull)
  status       String   @default("PENDING")
  message      String?  @db.Text
  initiatedBy  String   @default("GROOM")
  guardianNote String?  @db.Text
  conversation Conversation?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([senderId, profileId])
  @@index([brideId])
}

model Conversation {
  id             String   @id @default(cuid())
  requestId      String?  @unique
  request        ContactRequest? @relation(fields: [requestId], references: [id])
  type           String   @default("REQUEST")
  messages       Message[]
  participants   ConversationParticipant[]
  lastMessageAt  DateTime?
  createdAt      DateTime @default(now())
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  content        String       @db.Text
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  titleAr   String
  titleEn   String
  bodyAr    String
  bodyEn    String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Report {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation("Reporter", fields: [reporterId], references: [id])
  reportedId  String
  reported    User     @relation("Reported", fields: [reportedId], references: [id])
  reason      String
  details     String?  @db.Text
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}

model Post {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  mediaUrls String[]
  privacy   PostPrivacy @default(PUBLIC)
  isPinned  Boolean  @default(false)
  viewCount Int      @default(0)
  allowedUsers PostPrivacyUser[]
  likes     PostLike[]
  comments  PostComment[]
  sharedPostId String?
  sharedPost   Post?      @relation("PostReposts", fields: [sharedPostId], references: [id], onDelete: SetNull)
  reposts      Post[]     @relation("PostReposts")
  groupPost GroupPost?
  hashtags  PostHashtag[]
  mentions  PostMention[]
  saves     PostSave[]
  views     PostView[]
  reports   PostReport[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PostPrivacyUser {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String   @db.Text
  parentId  String?
  parent    PostComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   PostComment[] @relation("CommentReplies")
  likes     PostCommentLike[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model PostCommentLike {
  id        String      @id @default(cuid())
  commentId String
  comment   PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([commentId, userId])
  @@index([commentId])
}

model PostSave {
  id      String   @id @default(cuid())
  postId  String
  post    Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

model PostView {
  id       String   @id @default(cuid())
  postId   String
  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model Hashtag {
  id        String        @id @default(cuid())
  tag       String        @unique
  postCount Int           @default(0)
  posts     PostHashtag[]
  createdAt DateTime      @default(now())

  @@index([postCount])
}

model PostHashtag {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtagId String
  hashtag   Hashtag  @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@unique([postId, hashtagId])
  @@index([hashtagId])
}

model PostMention {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

model PostReport {
  id         String   @id @default(cuid())
  postId     String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User     @relation("PostReporter", fields: [reporterId], references: [id])
  reason     String
  details    String?  @db.Text
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())

  @@unique([postId, reporterId])
  @@index([status])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("BlockingUser", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Story {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaUrl  String
  mediaType String       @default("image")
  caption   String?
  privacy   StoryPrivacy @default(FOLLOWERS)
  expiresAt DateTime
  views     StoryView[]
  createdAt DateTime     @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model StoryView {
  id       String   @id @default(cuid())
  storyId  String
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId   String
  viewedAt DateTime @default(now())

  @@unique([storyId, userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Follower", fields: [followerId], references: [id])
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String?
  details   Json?
  createdAt DateTime @default(now())
}

enum FeedbackType {
  FEEDBACK
  BUG_REPORT
  FEATURE_REQUEST
  TESTIMONIAL
}

enum FeedbackStatus {
  PENDING
  APPROVED
  REJECTED
}

model Feedback {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      FeedbackType   @default(FEEDBACK)
  title     String
  content   String         @db.Text
  rating    Int?
  status    FeedbackStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

enum PaymentMethod {
  INSTAPAY
  VODAFONE_CASH
  USDT_TRC20
}

enum PaymentStatus {
  PENDING
  VERIFIED
  DECLINED
}

model Subscription {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount           Float         @default(150)
  durationMonths   Int           @default(1)
  paymentMethod    PaymentMethod
  transactionImage String?       @db.Text
  note             String?       @db.Text
  status           PaymentStatus @default(PENDING)
  adminNote        String?       @db.Text
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

model Donation {
  id               String        @id @default(cuid())
  userId           String?
  user             User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  amount           Float
  paymentMethod    PaymentMethod
  transactionImage String?       @db.Text
  note             String?       @db.Text
  status           PaymentStatus @default(PENDING)
  adminNote        String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
}

model Bride {
  id                    String   @id @default(cuid())
  guardianId            String
  guardian              User     @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  age                   Int
  dateOfBirth           String?
  weight                Int?
  height                Int?
  skinColor             String?
  healthIssues          String?

  education             String?
  educationName         String?
  occupation            String?
  workType              String?
  leaveWorkAfterMarriage String?
  incomeLevel           String?

  maritalStatus         String
  previousRelationship  String?
  previousMarriageCount Int?
  lastDivorceDate       String?
  husbandDeathDate      String?
  marriageCount         Int?
  childrenBoys          Int?
  childrenGirls         Int?
  childrenAges          String?
  custodyAfterMarriage  String?
  acceptPolygamy        String?
  wantChildren          String?

  fatherOccupation      String?
  motherOccupation      String?
  siblingsCount         Int?
  siblingsEducation     String?

  originGovernorate     String?
  residenceGovernorate  String?
  area                  String?
  areaType              String?

  prayerCommitment      String?
  hijabType             String?
  acceptNiqab           String?
  acceptTravel          String?
  formSubmitter         String?

  preferredAgeMin       Int?
  preferredAgeMax       Int?
  preferredSkinColor    String?
  preferredMaritalStatus String?
  acceptDivorcedWithChildren String?
  acceptDivorcedChildrenCustody String?
  acceptOtherGovernorate String?
  preferredEducation    String?
  preferredGeneralSpecs String?

  groomProvideApartment String?
  publishConsent        String?
  previousContact       String?
  notes                 String?

  status                String   @default("ACTIVE")
  iddahEndsAt           DateTime?
  iddahComplete         Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  exposures        BrideExposure[]
  contactRequests  ContactRequest[]

  @@index([guardianId])
}

model BrideExposure {
  id        String   @id @default(cuid())
  brideId   String
  bride     Bride    @relation(fields: [brideId], references: [id], onDelete: Cascade)
  groomId   String
  groom     User     @relation("GroomExposures", fields: [groomId], references: [id], onDelete: Cascade)
  isActive  Boolean  @default(true)
  exposedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([brideId, groomId])
  @@index([groomId])
  @@index([brideId])
}

model ConnectionRequest {
  id          String           @id @default(cuid())
  senderId    String
  sender      User             @relation("SentConnections", fields: [senderId], references: [id])
  receiverId  String
  receiver    User             @relation("ReceivedConnections", fields: [receiverId], references: [id])
  status      ConnectionStatus @default(PENDING)
  message     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([senderId, receiverId])
  @@index([receiverId])
}

model ServiceRequest {
  id           String               @id @default(cuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId   String
  category     ServiceCategory      @relation(fields: [categoryId], references: [id])
  title        String
  description  String               @db.Text
  budgetMin    Float?
  budgetMax    Float?
  currency     String               @default("EGP")
  governorate  String?
  city         String?
  latitude     Float?
  longitude    Float?
  urgency      String               @default("NORMAL")
  status       ServiceRequestStatus @default(OPEN)
  offers       ServiceOffer[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([status])
}

model ServiceOffer {
  id               String         @id @default(cuid())
  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  providerId       String
  provider         User           @relation("ProviderOffers", fields: [providerId], references: [id])
  price            Float
  message          String         @db.Text
  status           String         @default("PENDING")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([serviceRequestId, providerId])
  @@index([providerId])
}

model ServiceBookingPayment {
  id            String                  @id @default(cuid())
  bookingId     String                  @unique
  booking       ServiceBooking          @relation(fields: [bookingId], references: [id])
  amount        Float
  currency      String                  @default("EGP")
  method        PaymentMethod
  proofImage    String?                 @db.Text
  status        MarketplacePaymentStatus @default(PENDING)
  note          String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
}

model OrderPayment {
  id        String                  @id @default(cuid())
  orderId   String                  @unique
  order     Order                   @relation(fields: [orderId], references: [id])
  amount    Float
  currency  String                  @default("EGP")
  method    PaymentMethod
  proofImage String?                @db.Text
  status    MarketplacePaymentStatus @default(PENDING)
  note      String?
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
}

model Group {
  id          String       @id @default(cuid())
  name        String
  nameAr      String?
  description String       @db.Text
  avatar      String?
  banner      String?
  privacy     GroupPrivacy @default(PUBLIC)
  createdById String
  createdBy   User         @relation("CreatedGroups", fields: [createdById], references: [id])
  members     GroupMember[]
  posts       GroupPost[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([privacy])
}

model GroupMember {
  id        String          @id @default(cuid())
  groupId   String
  group     Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      GroupMemberRole @default(MEMBER)
  joinedAt  DateTime        @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model GroupPost {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  postId    String   @unique
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
  CANCELLED
}

model ServiceCategory {
  id        String   @id @default(cuid())
  nameAr    String
  nameEn    String?
  nameFr    String?
  nameUr    String?
  icon      String?
  parentId  String?
  parent    ServiceCategory? @relation("CategoryTree", fields: [parentId], references: [id])
  children  ServiceCategory[] @relation("CategoryTree")
  services  Service[]
  serviceRequests ServiceRequest[]
  createdAt DateTime @default(now())
}

model Service {
  id               String         @id @default(cuid())
  providerId       String
  provider         User           @relation("ProviderServices", fields: [providerId], references: [id], onDelete: Cascade)
  categoryId       String
  category         ServiceCategory @relation(fields: [categoryId], references: [id])
  title            String
  description      String         @db.Text
  price            Float
  priceUnit        String         @default("FIXED")
  currency         String         @default("EGP")
  latitude         Float?
  longitude        Float?
  address          String?
  city             String?
  governorate      String?
  images           String[]
  status           ServiceStatus  @default(ACTIVE)
  viewCount        Int            @default(0)
  islamicCategory  String?
  isHalalCertified Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  bookings         ServiceBooking[]
  reviews          ServiceReview[]
}

model ServiceBooking {
  id         String        @id @default(cuid())
  serviceId  String
  service    Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  clientId   String
  client     User          @relation("ClientBookings", fields: [clientId], references: [id])
  message    String?       @db.Text
  status     BookingStatus @default(PENDING)
  payment    ServiceBookingPayment?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model ServiceReview {
  id         String   @id @default(cuid())
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User     @relation("ReviewerReviews", fields: [reviewerId], references: [id])
  rating     Int
  content    String?  @db.Text
  createdAt  DateTime @default(now())
}

enum StoreStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model ProductCategory {
  id        String    @id @default(cuid())
  nameAr    String
  nameEn    String?
  nameFr    String?
  nameUr    String?
  icon      String?
  products  Product[]
  createdAt DateTime  @default(now())
}

model Store {
  id              String       @id @default(cuid())
  ownerId         String       @unique
  owner           User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name            String
  description     String       @db.Text
  slug            String       @unique
  logo            String?
  banner          String?
  images          String[]
  latitude        Float?
  longitude       Float?
  address         String?
  city            String?
  governorate     String?
  phone           String?
  status          StoreStatus  @default(ACTIVE)
  isHalalCertified  Boolean    @default(false)
  halalCertBody     String?
  islamicCategory   String?
  products        Product[]
  orders          Order[]      @relation("StoreOrders")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([ownerId])
  @@index([slug])
  @@index([status])
}

model Product {
  id          String         @id @default(cuid())
  storeId     String
  store       Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId  String
  category    ProductCategory @relation(fields: [categoryId], references: [id])
  name        String
  description String         @db.Text
  price       Float
  currency    String         @default("EGP")
  images      String[]
  stock       Int            @default(0)
  status      ProductStatus  @default(ACTIVE)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([storeId])
  @@index([categoryId])
  @@index([status])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  @@unique([cartId, productId])
  @@index([cartId])
}

model Order {
  id                  String       @id @default(cuid())
  buyerId             String
  buyer               User         @relation("BuyerOrders", fields: [buyerId], references: [id])
  storeId             String
  store               Store        @relation("StoreOrders", fields: [storeId], references: [id])
  total               Float
  currency            String       @default("EGP")
  status              OrderStatus  @default(PENDING)
  shippingAddress     String?
  shippingCity        String?
  shippingGovernorate String?
  notes               String?      @db.Text
  items               OrderItem[]
  payment             OrderPayment?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([buyerId])
  @@index([storeId])
  @@index([status])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  productName String
  price       Float
  quantity    Int

  @@index([orderId])
}
